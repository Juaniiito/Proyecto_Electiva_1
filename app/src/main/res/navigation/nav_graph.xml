<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.taskflow.app.ui.main.MainFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_main">
        <action
            android:id="@+id/action_mainFragment_to_taskEditorFragment"
            app:destination="@id/taskEditorFragment" />
    </fragment>

    <fragment
        android:id="@+id/taskEditorFragment"
        android:name="com.taskflow.app.ui.editor.TaskEditorFragment"
        tools:layout="@layout/fragment_task_editor">
        <argument
            android:name="taskId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>
</navigation>
